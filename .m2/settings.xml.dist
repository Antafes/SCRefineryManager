<?xml version="1.0" encoding="UTF-8"?>
<settings xmlns="http://maven.apache.org/SETTINGS/1.0.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.0.0 http://maven.apache.org/xsd/settings-1.0.0.xsd">
    <activeProfiles>
        <activeProfile>github</activeProfile>
    </activeProfiles>
    <profiles>
        <profile>
            <id>github</id>
            <repositories>
                <repository>
                    <id>github-utilities</id>
                    <url>https://maven.pkg.github.com/antafes/utilities</url>
                    <releases><enabled>true</enabled></releases>
                    <snapshots>
                        <enabled>true</enabled>
                    </snapshots>
                </repository>
                <repository>
					<id>github-event-dispatcher</id>
					<url>https://maven.pkg.github.com/antafes/eventdispatcher</url>
                    <releases><enabled>true</enabled></releases>
					<snapshots><enabled>true</enabled></snapshots>
				</repository>
                <repository>
                    <id>github-sc-base</id>
                    <url>https://maven.pkg.github.com/antafes/SCBase</url>
                    <releases><enabled>true</enabled></releases>
                    <snapshots>
                        <enabled>true</enabled>
                    </snapshots>
                </repository>
                <repository>
                    <id>github-sc-refman</id>
                    <url>https://maven.pkg.github.com/antafes/SCRefineryManager</url>
                    <releases><enabled>true</enabled></releases>
                    <snapshots>
                        <enabled>true</enabled>
                    </snapshots>
                </repository>
                <repository>
                    <id>central</id>
                    <url>https://repo1.maven.org/maven2</url>
                    <releases><enabled>true</enabled></releases>
                    <snapshots><enabled>true</enabled></snapshots>
                </repository>
            </repositories> 
        </profile>
    </profiles>
    
    <servers>
        <server>
            <id>github-utilities</id>
            <username>[[YourUsernameHere]]</username>
            <password>[[YourPasswordHere]]</password>
        </server>
        <server>
            <id>github-event-dispatcher</id>
            <username>[[YourUsernameHere]]</username>
            <password>[[YourPasswordHere]]</password>
        </server>
        <server>
            <id>github-sc-base</id>
            <username>[[YourUsernameHere]]</username>
            <password>[[YourPasswordHere]]</password>
        </server>
        <server>
            <id>github-sc-refman</id>
            <username>[[YourUsernameHere]]</username>
            <password>[[YourPasswordHere]]</password>
        </server>
    </servers>
</settings>
